# .gitignore for Python project
# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Virtual environment
venv/
ENV/
env/
.venv/
venv*/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace

# Jupyter
.ipynb_checkpoints

# Testing / linting
.pytest_cache/
.mypy_cache/

# Coverage reports
.coverage
coverage.xml

# Logs and temp files
logs/
*.log
tmp/
temp/

# OS files
.DS_Store

# Environment variables
.env
.env.*

# Local settings
local_settings.py

